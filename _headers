# HTTP response headers for Cloudflare Pages.

# Security headers applied to every route.
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), usb=(), payment=()
  Strict-Transport-Security: max-age=31536000

# Content-Security-Policy is enforced on the home page; still Report-Only
# on the resume page (it loads the Tailwind Play CDN, kept under observation).
# Each inline <script> is allowed by its SHA-256 hash, not 'unsafe-inline'.
# https://static.cloudflareinsights.com is Cloudflare Web Analytics (auto-injected).

# Home page — self-contained, so a strict policy.
/
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-dIuEdUtr3RKYD+2HeuCTqijNXfcfCI8Jzx2lDooBRHQ=' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self'; connect-src 'self' https://cloudflareinsights.com; object-src 'none'; base-uri 'self'; frame-ancestors 'none'
/index.html
  Content-Security-Policy: default-src 'self'; script-src 'self' 'sha256-dIuEdUtr3RKYD+2HeuCTqijNXfcfCI8Jzx2lDooBRHQ=' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self'; connect-src 'self' https://cloudflareinsights.com; object-src 'none'; base-uri 'self'; frame-ancestors 'none'

# Resume page — loads the Tailwind Play CDN and Google Fonts, so a looser policy.
/resume.html
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'sha256-QVQo+myCtXcJTIHKIxXHpQ47Z2XmXfhfxOCNgHWLIL4=' 'unsafe-eval' https://cdn.tailwindcss.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://cloudflareinsights.com; object-src 'none'; base-uri 'self'; frame-ancestors 'none'
/resume
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'sha256-QVQo+myCtXcJTIHKIxXHpQ47Z2XmXfhfxOCNgHWLIL4=' 'unsafe-eval' https://cdn.tailwindcss.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://cloudflareinsights.com; object-src 'none'; base-uri 'self'; frame-ancestors 'none'
